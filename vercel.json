{
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.urbanpaws.app" }],
      "destination": "https://urbanpaws.app/my-bookings.html",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "app.urbanpaws.app" }],
      "destination": "https://urbanpaws.app/my-bookings.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.urbanpaws.app" }],
      "destination": "https://urbanpaws.app/admin.html",
      "permanent": false
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.urbanpaws.app" }],
      "destination": "https://urbanpaws.app/admin.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
