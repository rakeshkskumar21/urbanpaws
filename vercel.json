{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "admin.urbanpaws.app" }],
      "destination": "/admin"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "app.urbanpaws.app" }],
      "destination": "/bookings"
    },
    { "source": "/bookings", "destination": "/my-bookings" },
    { "source": "/bookings/(.*)", "destination": "/my-bookings" },
    { "source": "/dashboard", "destination": "/executive-dashboard" },
    { "source": "/dashboard/(.*)", "destination": "/executive-dashboard" },
    { "source": "/login", "destination": "/executive-login" },
    { "source": "/login/(.*)", "destination": "/executive-login" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
