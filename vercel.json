{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/bookings", "destination": "/my-bookings" },
    { "source": "/bookings/(.*)", "destination": "/my-bookings" },
    { "source": "/dashboard", "destination": "/executive-dashboard" },
    { "source": "/dashboard/(.*)", "destination": "/executive-dashboard" },
    { "source": "/login", "destination": "/executive-login" },
    { "source": "/login/(.*)", "destination": "/executive-login" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
